# ============================================================
#  RESCAPE — Variables d'environnement
#  Dev  → copiez vers .env.local
#  Prod → configurez dans Vercel > Settings > Environment Variables
# ============================================================

# ── Base de données ──────────────────────────────────────────
# Dev (SQLite) : laisser vide — le fallback file:./prisma/dev.db s'applique
# Prod (Supabase) : récupérer la "Session Pooler" URL dans
#   Supabase > Project Settings > Database > Connection string
#   Choisir le mode "Session" (port 5432) — NE PAS utiliser le mode Transaction
#   car Prisma n'est pas compatible avec le mode Transaction (port 6543)
#
# DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-eu-west-3.pooler.supabase.com:5432/postgres"

# ── Authentification (NextAuth.js) ───────────────────────────
# Générer via : npx auth secret   OU   openssl rand -base64 32
AUTH_SECRET="CHANGEZ_MOI_clé_aléatoire_32_caractères"

# URL publique du site (obligatoire en production)
# NEXTAUTH_URL="https://www.rescape-asso.com"

# ── Email / SMTP ─────────────────────────────────────────────
# En dev : si SMTP_HOST est absent, les mails s'affichent en console
# SMTP_HOST="mail.rescape.org"
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER="contact@rescape.org"
# SMTP_PASS="votre_mot_de_passe_smtp"
# SMTP_FROM="contact@rescape.org"

# Email qui recevra les notifications de contact
# ADMIN_EMAIL="direction@rescape.org"
