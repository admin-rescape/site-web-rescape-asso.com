# ============================================================
#  RESCAPE — Variables d'environnement
#  Copiez ce fichier vers .env.local (dev) ou configurez
#  ces variables dans Vercel > Settings > Environment Variables
# ============================================================

# ── Base de données ──────────────────────────────────────────
# Dev (SQLite) : ne rien mettre, le fallback file:./prisma/dev.db s'applique
# Prod (PostgreSQL Vercel/Supabase/Neon) :
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# ── Authentification (NextAuth.js) ───────────────────────────
# Générer via : openssl rand -base64 32
AUTH_SECRET="CHANGEZ_MOI_clé_aléatoire_32_caractères"

# URL du site (obligatoire en production)
# NEXTAUTH_URL="https://votre-domaine.vercel.app"

# ── Email / SMTP ─────────────────────────────────────────────
# En dev : si SMTP_HOST est absent, les mails s'affichent en console
# SMTP_HOST="mail.rescape.org"
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER="contact@rescape.org"
# SMTP_PASS="votre_mot_de_passe_smtp"
# SMTP_FROM="contact@rescape.org"

# Email qui recevra les notifications de contact
# ADMIN_EMAIL="direction@rescape.org"
