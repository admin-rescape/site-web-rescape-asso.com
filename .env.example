# ============================================================
#  RESCAPE — Variables d'environnement
#  Dev  → copiez vers .env.local  (ne pas committer !)
#  Prod → configurez dans Vercel > Settings > Environment Variables
# ============================================================

# ── Base de données ──────────────────────────────────────────
# Dev (SQLite) : laisser vide — le fallback file:./prisma/dev.db s'applique
# Prod (Supabase) : utiliser le mode "Transaction" pooler (port 6543)
#   avec ?pgbouncer=true ajouté à l'URL.
#   Supabase > Project Settings > Database > Connection string > Transaction
#
# DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-eu-west-3.pooler.supabase.com:6543/postgres?pgbouncer=true"

# ── SSL PostgreSQL ───────────────────────────────────────────
# Supabase utilise un certificat auto-signé pour le pooler : mettre à false.
# Sur d'autres providers (Railway, Neon…) laisser à true (valeur par défaut).
# PG_SSL_REJECT_UNAUTHORIZED=false

# ── Authentification (NextAuth.js v5) ────────────────────────
# Générer via : npx auth secret   OU   openssl rand -base64 32
AUTH_SECRET="CHANGEZ_MOI_clé_aléatoire_32_caractères"

# ⚠️  OBLIGATOIRE en production pour éviter la redirection vers localhost:3000
#     Doit correspondre à l'URL publique exacte (sans slash final).
NEXTAUTH_URL="https://www.rescape-asso.com"

# ── Email / SMTP ─────────────────────────────────────────────
# En dev : si SMTP_HOST est absent, les mails s'affichent en console
# SMTP_HOST="mail.rescape.org"
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER="contact@rescape.org"
# SMTP_PASS="votre_mot_de_passe_smtp"
# SMTP_FROM="contact@rescape.org"

# Email qui recevra les notifications de contact
# ADMIN_EMAIL="direction@rescape.org"

# ── Tests E2E (Playwright) ────────────────────────────────────
# Mot de passe partagé des comptes de test — injecter via CI secret, ne jamais committer.
# E2E_TEST_PASSWORD="..."
